---
import { ACQUISITION_MAILTO } from '../config/site';
---

<section id="acquire" class="py-20 bg-zinc-900 border-b border-white/10">
  <div class="max-w-2xl mx-auto px-6 text-center">
    <p class="text-xs uppercase tracking-[3px] text-amber-400 font-extrabold mb-4">Ready to Own the Narrative?</p>
    <h2 class="font-display text-4xl md:text-5xl tracking-tight mb-6">
      <span class="monster-text">script.monster</span> is available for strategic acquisition.
    </h2>
    <p class="text-zinc-400 mb-4 leading-relaxed">
      This is not a mass-market listing. It is a premium opportunity for the right buyer — someone who
      sees the monster and wants to unleash it at scale.
    </p>
    <p class="text-zinc-400 mb-8 leading-relaxed">
      Serious inquiries and qualified buyers only. Pricing reflects the asset's positioning, scarcity,
      and brand potential.
    </p>

    <a
      href={ACQUISITION_MAILTO}
      class="inline-flex items-center justify-center gap-x-3 px-10 h-14 rounded-3xl bg-white text-zinc-950 font-semibold text-lg hover:bg-zinc-100 active:scale-[0.985] transition-all shadow-xl"
    >
      Contact for Acquisition Details
      <i class="fa-solid fa-arrow-right"></i>
    </a>

    <div class="mt-6 text-xs text-zinc-500">
      Let's discuss how this domain becomes the foundation of something monstrously good.
    </div>
  </div>
</section>
